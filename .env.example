# Copy this file to .env and fill in real values. Never commit .env.

# ── Postgres (required) ──────────────────────────────────────────────────────
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Azure OpenAI — primary LLM provider ──────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=your_deployment_name_here

# ── Fallback LLM providers (used if Azure OpenAI is unavailable/rate-limited) ─
GROQ_API_KEY=your_groq_api_key_here            # https://console.groq.com
CEREBRAS_API_KEY=your_cerebras_api_key_here    # https://cloud.cerebras.ai
OPENAI_API_KEY=your_openai_api_key_here        # https://platform.openai.com
OPENAI_BASE_URL=https://api.openai.com/v1      # or an OpenAI-compatible endpoint
OPENROUTER_API_KEY=your_openrouter_api_key_here  # https://openrouter.ai

# ── CLI-only (nlsql.py) ───────────────────────────────────────────────────────
AI_USER_EMAIL=someone@example.com   # default role-lookup email for the REPL, optional
LOG_LEVEL=WARNING                    # WARNING (default) | INFO | DEBUG
